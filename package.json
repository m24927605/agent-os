{
  "name": "agent-os",
  "version": "0.0.0",
  "private": true,
  "description": "Agent OS — secure, policy-governed agent runtime built as a layer above NVIDIA OpenShell (integration strategy B).",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "agentos": "./dist/cli/main.js" },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "deps:check": "depcruise src --config .dependency-cruiser.cjs",
    "proto:gen": "bash scripts/proto-gen.sh",
    "proto:check": "bash scripts/proto-check.sh",
    "openshell:proto:check": "bash scripts/openshell-proto-check.sh",
    "spendguard:proto:gen": "bash scripts/spendguard-proto-gen.sh",
    "spendguard:proto:check": "bash scripts/spendguard-proto-check.sh",
    "verify:p1-exit": "bash scripts/verify-p1-exit.sh",
    "verify:go": "env -u GOROOT CGO_ENABLED=0 GOTOOLCHAIN=local bash scripts/verify-go.sh",
    "verifier:release": "env -u GOROOT GOTOOLCHAIN=local bash scripts/build-verifier-release.sh",
    "verify:py": "bash scripts/verify-py.sh",
    "verify:cross-tenant": "env -u GOROOT CGO_ENABLED=0 GOTOOLCHAIN=local bash scripts/verify-cross-tenant.sh",
    "secret-scan": "bash scripts/scan_secrets.sh",
    "launcher:check": "node scripts/launcher-check.mjs",
    "e2e:live-kernel": "bash scripts/e2e-live-kernel.sh",
    "e2e:live-enterprise": "bash scripts/e2e-live-enterprise.sh",
    "e2e:live-spendguard": "bash scripts/e2e-live-spendguard.sh",
    "e2e:live-nemoclaw": "bash scripts/e2e-live-nemoclaw.sh",
    "e2e:live-hermes": "bash scripts/e2e-live-hermes.sh",
    "e2e:live-desktop-hermes": "bash scripts/e2e-live-desktop-hermes.sh",
    "e2e:live-developer": "bash scripts/e2e-live-developer.sh",
    "e2e:live-kernel-verify": "bash scripts/e2e-live-kernel-verify.sh",
    "e2e:live-partition-verify": "bash scripts/e2e-live-partition-verify.sh",
    "e2e:live-substrate-exec": "bash scripts/e2e-live-substrate-exec.sh",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run build && pnpm run test && pnpm run deps:check && pnpm run proto:check && pnpm run openshell:proto:check && pnpm run spendguard:proto:check && pnpm run verify:go && pnpm run verify:py && pnpm run verify:cross-tenant && pnpm run launcher:check && pnpm run secret-scan"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@bufbuild/protobuf": "^2.12.0",
    "@connectrpc/connect": "^2.1.2",
    "@connectrpc/connect-node": "^2.1.2",
    "@types/node": "^22.10.2",
    "dependency-cruiser": "^17.4.3",
    "ts-proto": "2.11.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

{
  "name": "agent-os",
  "version": "0.0.0",
  "private": true,
  "description": "Agent OS — secure, policy-governed agent runtime built as a layer above NVIDIA OpenShell (integration strategy B).",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "secret-scan": "bash scripts/scan_secrets.sh",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run build && pnpm run test && pnpm run secret-scan"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
